<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>CB-App Ultimate</title>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        :root { 
            --primary: #ff7675; --secondary: #a29bfe; --bg: #0f0c29; 
            --card: #ffffff; --text: #2d3436; --muted: #636e72; 
            --accent-green: #00b894; --accent-red: #fab1a0; --light-bg: #f8fafc;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body { 
            font-family: 'Outfit', sans-serif; background: #0f0c29; 
            margin: 0; padding: 0; height: 100vh; width: 100vw;
            display: flex; justify-content: center; overflow: hidden;
        }
        
        .container { 
            width: 100%; max-width: 450px; height: 100vh; background: var(--card); 
            display: flex; flex-direction: column;
            padding: env(safe-area-inset-top) 25px env(safe-area-inset-bottom) 25px;
            position: relative;
        }

        /* HEADER */
        .header { height: 60px; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; border-bottom: 2px solid #f1f2f6; }
        .brand { font-size: 1.6rem; font-weight: 600; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        /* CONTENT AREA */
        .main-scroll { flex-grow: 1; overflow-y: auto; padding: 20px 0; -webkit-overflow-scrolling: touch; }

        /* FOOTER BUTTONS */
        .footer { height: 110px; display: flex; flex-direction: column; justify-content: center; flex-shrink: 0; background: white; border-top: 2px solid #f1f2f6; gap: 8px; }
        
        .btn-action { 
            width: 100%; padding: 18px; border-radius: 22px; border: none;
            background: linear-gradient(135deg, var(--primary), var(--secondary)); 
            color: white; font-weight: 600; font-size: 1.1rem; cursor: pointer;
            box-shadow: 0 8px 15px rgba(255, 118, 117, 0.3);
            animation: pulseBtn 2s infinite;
        }
        @keyframes pulseBtn { 0% { transform: scale(1); } 50% { transform: scale(1.02); } 100% { transform: scale(1); } }
        .btn-action:active { transform: scale(0.95); animation: none; }

        .btn-secondary { background: #f1f2f6; color: var(--muted); padding: 10px; border-radius: 14px; border: none; font-size: 0.8rem; cursor: pointer; transition: 0.3s; }
        .btn-secondary:hover { background: #e2e3e9; }

        /* ANIMATIONEN & STATUS */
        .status-pill { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 50px; font-weight: 600; font-size: 0.85rem; }
        .status-ready { background: #e3faf3; color: var(--accent-green); }
        .status-wait { background: #fff1f1; color: var(--primary); }

        .dot-pulse { width: 10px; height: 10px; border-radius: 50%; background: currentColor; animation: pulseDot 1.5s infinite; }
        @keyframes pulseDot { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(1.3); } 100% { opacity: 1; transform: scale(1); } }

        /* QUIZ */
        .prog { display: flex; justify-content: center; gap: 8px; margin-bottom: 20px; }
        .dot { width: 30px; height: 6px; border-radius: 10px; background: #eee; transition: 0.4s; }
        .dot.active { background: var(--secondary); width: 50px; }
        .dot.done { background: var(--accent-green); }

        .info-tab { background: #f1f2ff; border-radius: 16px; padding: 12px; margin-bottom: 20px; border-left: 5px solid var(--secondary); font-size: 0.85rem; color: #574b90; }

        /* RANKING */
        .rank-card { background: var(--light-bg); border: 2px solid #edf2f7; padding: 16px; margin-bottom: 10px; border-radius: 20px; display: flex; align-items: center; gap: 15px; cursor: grab; }
        .rank-circle { background: var(--secondary); color: white; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 600; }
        .sortable-ghost { opacity: 0.2; background: var(--secondary); }

        .tot-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .tot-card { background: var(--light-bg); border: 2px solid #edf2f7; border-radius: 24px; padding: 30px 10px; text-align: center; font-weight: 600; min-height: 100px; display: flex; align-items: center; justify-content: center; transition: 0.3s; }
        .tot-card.selected { background: var(--primary); color: white; border-color: var(--primary); transform: translateY(-5px); box-shadow: 0 5px 15px rgba(255,118,117,0.3); }

        textarea { width: 100%; height: 140px; border-radius: 20px; border: 2px solid #eee; padding: 15px; font-family: inherit; font-size: 1.1rem; outline: none; background: var(--light-bg); }

        /* VERGLEICH */
        .res-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
        .res-bubble { padding: 12px; border-radius: 18px; font-size: 0.85rem; border: 1px solid #eee; min-height: 70px; display: flex; flex-direction: column; }
        .res-bubble b { font-size: 0.65rem; opacity: 0.5; text-transform: uppercase; margin-bottom: 5px; }

        .hidden { display: none !important; }
        .login-field { width: 100%; padding: 18px; margin-bottom: 12px; border-radius: 18px; border: 2px solid #eee; font-size: 1rem; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div class="brand" id="brand-text">CB-App</div>
        <button id="logout-btn" class="btn-secondary hidden" onclick="app.logout()">Abmelden 🚪</button>
    </div>

    <div id="main-content" class="main-scroll">
        </div>

    <div class="footer" id="footer-ui">
        <button id="action-btn" class="btn-action">Laden...</button>
    </div>
</div>

<script>
    const SB_URL = "https://eedbdbqvwpquoxzbunwo.supabase.co";
    const SB_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVlZGJkYnF2d3BxdW94emJ1bndvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2NzY0NDEsImV4cCI6MjA5MjI1MjQ0MX0.7RKZjDKvieO-hoCpORQeA9uFcGhLqHNTGwvYiK5ogrs";
    const sb = supabase.createClient(SB_URL, SB_KEY);

    const pool = {
        tot: [{q: "Morgenstund?", o: ["Ausschlafen 😴", "Früh sporteln 🏃"], i: "Tippe deine Wahl an!"}],
        ranking: [{q: "Beste Date-Idee?", o: ["Picknick", "Kino", "Kochen", "Wandern"], i: "Halte die Karten und schiebe Platz 1 nach oben."}],
        text: [{q: "Was liebst du an heute?", o: [], i: "Schreib eine Nachricht für deinen Partner."}]
    };

    const app = {
        user: "", partner: "", day: new Date().toISOString().split('T')[0],
        step: 0, results: [], dailyQs: [], isSubmitting: false,

        async init() {
            window.onpopstate = (e) => {
                if (e.state) {
                    this.step = e.state.step; this.results = e.state.results;
                    if (e.state.view === 'lobby') this.showLobby(false);
                    if (e.state.view === 'quiz') this.renderQuiz(false);
                    if (e.state.view === 'results') this.showComparison(false);
                }
            };

            const { data: { session } } = await sb.auth.getSession();
            if (!session) return this.renderLogin();
            
            this.user = session.user.email.toLowerCase() === 'bisf@gmx.de' ? "bene" : "clara";
            this.partner = this.user === "bene" ? "clara" : "bene";
            
            document.getElementById('logout-btn').classList.remove('hidden');
            document.getElementById('brand-text').innerText = "Hi " + this.user.charAt(0).toUpperCase() + this.user.slice(1);
            this.showLobby();
        },

        updateHistory(view) {
            history.pushState({ view, step: this.step, results: [...this.results] }, "");
        },

        async showLobby(push = true) {
            if (push) this.updateHistory('lobby');
            const { data } = await sb.from('answers').select('*').eq('day_key', this.day);
            const me = data?.find(a => a.user_name === this.user);
            const other = data?.find(a => a.user_name === this.partner);

            document.getElementById('main-content').innerHTML = `
                <h2 style="text-align:left; margin-top:10px;">Dein Dashboard</h2>
                <div style="background:var(--light-bg); border-radius:20px; padding:25px; border:1px solid #eee;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:20px; align-items:center;">
                        <span>Ich:</span> 
                        <span class="status-pill ${me?'status-ready':'status-wait'}">
                            ${me?'Fertig ✅':'Offen'}${me?'':'<span class="dot-pulse"></span>'}
                        </span>
                    </div>
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <span>${this.partner.toUpperCase()}:</span> 
                        <span class="status-pill ${other?'status-ready':'status-wait'}">
                            ${other?'Fertig ✅':'Überlegt...'}${other?'':'<span class="dot-pulse"></span>'}
                        </span>
                    </div>
                </div>
            `;
            const btn = document.getElementById('action-btn');
            btn.innerText = me ? "Vergleich ansehen ✨" : "Heute starten 🚀";
            btn.onclick = () => me ? this.showComparison() : this.startQuiz();
        },

        startQuiz() {
            const seed = parseInt(this.day.replace(/-/g, ''));
            this.dailyQs = [pool.tot[seed % pool.tot.length], pool.ranking[seed % pool.ranking.length], pool.text[seed % pool.text.length]];
            this.step = 0; this.results = []; this.renderQuiz();
        },

        renderQuiz(push = true) {
            if (push) this.updateHistory('quiz');
            const q = this.dailyQs[this.step];
            document.getElementById('main-content').innerHTML = `
                <div class="prog">${[0,1,2].map(i => `<div class="dot ${i===this.step?'active':(i<this.step?'done':'')}"></div>`).join('')}</div>
                <div class="info-tab"><b>MODUS:</b> ${q.o.length === 2 ? 'This or That' : (q.o.length > 2 ? 'Ranking' : 'Gedanken')}</div>
                <h2>${q.q}</h2>
                <div id="quiz-input"></div>
            `;

            const wrap = document.getElementById('quiz-input');
            if (q.o.length === 2) {
                wrap.className = "tot-grid";
                q.o.forEach(o => {
                    const d = document.createElement('div'); d.className = "tot-card"; d.innerText = o;
                    d.onclick = () => { document.querySelectorAll('.tot-card').forEach(c => c.classList.remove('selected')); d.classList.add('selected'); };
                    wrap.appendChild(d);
                });
            } else if (q.o.length > 2) {
                q.o.forEach((o, i) => {
                    const d = document.createElement('div'); d.className = "rank-card";
                    d.innerHTML = `<span class="rank-circle">${i+1}</span><span>${o}</span>`; wrap.appendChild(d);
                });
                new Sortable(wrap, { animation: 250, forceFallback: true, ghostClass: 'sortable-ghost', onEnd: () => { document.querySelectorAll('.rank-circle').forEach((n, idx) => n.innerText = idx + 1); }});
            } else {
                wrap.innerHTML = `<textarea id="txt-val" placeholder="Deine Nachricht..."></textarea>`;
            }

            const btn = document.getElementById('action-btn');
            btn.innerText = this.step < 2 ? "Weiter ✨" : `An ${this.partner} senden ✈️`;
            btn.onclick = () => this.handleNext();
        },

        handleNext() {
            const q = this.dailyQs[this.step];
            let val = "";
            if (q.o.length === 2) val = document.querySelector('.tot-card.selected')?.innerText;
            else if (q.o.length > 2) val = Array.from(document.querySelectorAll('.rank-card span:last-child')).map(s => s.innerText).join(" > ");
            else val = document.getElementById('txt-val').value.trim();

            if (!val) return alert("Antwort fehlt noch! ✨");
            this.results.push(val);
            if (this.step < 2) { this.step++; this.renderQuiz(); }
            else this.submit();
        },

        async submit() {
            if (this.isSubmitting) return;
            this.isSubmitting = true;
            const btn = document.getElementById('action-btn');
            btn.disabled = true; btn.innerText = "Sende...";
            
            const { error } = await sb.from('answers').insert([{ user_name: this.user, choice: this.results.join(" | "), day_key: this.day }]);
            this.isSubmitting = false;
            if (error) { alert("Senden fehlgeschlagen! Fehler: " + error.message); btn.disabled = false; btn.innerText = "Nochmal versuchen"; }
            else { confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } }); this.showComparison(); }
        },

        async showComparison(push = true) {
            if (push) this.updateHistory('results');
            const { data } = await sb.from('answers').select('*').eq('day_key', this.day);
            const me = data?.find(a => a.user_name === this.user);
            const other = data?.find(a => a.user_name === this.partner);
            const myA = me.choice.split(" | "), otherA = other ? other.choice.split(" | ") : null;

            document.getElementById('main-content').innerHTML = `<h2>Euer Vergleich</h2><div id="res-list"></div>`;
            const seed = parseInt(this.day.replace(/-/g, ''));
            const qs = [pool.tot[seed % pool.tot.length], pool.ranking[seed % pool.ranking.length], pool.text[seed % pool.text.length]];
            
            qs.forEach((q, i) => {
                document.getElementById('res-list').innerHTML += `
                    <div style="margin-bottom:15px;"><div style="font-size:0.75rem; font-weight:600; color:var(--muted); text-transform:uppercase; margin-bottom:8px;">${q.q}</div>
                    <div class="res-grid">
                        <div class="res-bubble" style="background:#f1f0ff; border-color:var(--secondary);"><b>ICH</b>${myA[i]}</div>
                        <div class="res-bubble" style="background:${otherA?'#e3faf3':'#fff1f1'};"><b>${this.partner.toUpperCase()}</b>${otherA ? otherA[i] : '⌛ Wartet...'}</div>
                    </div></div>`;
            });
            const footer = document.getElementById('footer-ui');
            footer.innerHTML = `
                <button class="btn-action" onclick="app.showLobby()">Dashboard 🏠</button>
                <button class="btn-secondary" onclick="app.deleteMyAnswer()" style="margin-top:5px;">Antwort korrigieren 📝</button>
            `;
        },

        async deleteMyAnswer() {
            if (!confirm("Deine heutigen Antworten wirklich löschen?")) return;
            await sb.from('answers').delete().eq('day_key', this.day).eq('user_name', this.user);
            location.reload();
        },

        renderLogin() {
            document.getElementById('main-content').innerHTML = `
                <h2 style="margin-top:20px;">Anmelden</h2>
                <input id="em" type="email" class="login-field" placeholder="E-Mail">
                <input id="pw" type="password" class="login-field" placeholder="Passwort">
            `;
            const btn = document.getElementById('action-btn');
            btn.innerText = "Einloggen";
            btn.onclick = async () => {
                const { error } = await sb.auth.signInWithPassword({ email: document.getElementById('em').value, password: document.getElementById('pw').value });
                if (error) alert("Login Fehler: " + error.message); else location.reload();
            };
        },
        async logout() { await sb.auth.signOut(); location.reload(); }
    };
    app.init();
</script>
</body>
</html>
